#include <winver.h>

1 24 "@CASEDASH_MANIFEST_PATH@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @CASEDASH_WIN32_VERSION_COMMA@
 PRODUCTVERSION @CASEDASH_WIN32_VERSION_COMMA@
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
 FILEFLAGS @CASEDASH_WIN32_FILEFLAGS@
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Roman Elizarov\0"
            VALUE "FileDescription", "@CASEDASH_FILE_DESCRIPTION@\0"
            VALUE "FileVersion", "@CASEDASH_VERSION@\0"
            VALUE "InternalName", "CaseDash\0"
            VALUE "LegalCopyright", "Copyright (c) Roman Elizarov\0"
            VALUE "OriginalFilename", "@CASEDASH_ORIGINAL_FILENAME@\0"
            VALUE "ProductName", "CaseDash\0"
            VALUE "ProductVersion", "@CASEDASH_VERSION@\0"
            VALUE "SpecialBuild", "@CASEDASH_SPECIAL_BUILD@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
